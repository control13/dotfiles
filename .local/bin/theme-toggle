#!/usr/bin/env bash
set -euo pipefail

LIGHT_THEME="Adwaita"
DARK_THEME="Adwaita-dark"

get_mode() {
  local current
  current="$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || echo "'default'")"
  if [[ "${current}" == "'prefer-dark'" ]]; then
    echo "dark"
  else
    echo "light"
  fi
}

apply_mode() {
  local mode="$1"

  if [[ "${mode}" == "dark" ]]; then
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
    gsettings set org.gnome.desktop.interface gtk-theme "${DARK_THEME}"
  else
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-light'
    gsettings set org.gnome.desktop.interface gtk-theme "${LIGHT_THEME}"
  fi

  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Theme switched" "${mode}"
  fi
}

print_status() {
  local mode="$1"
  if [[ "${mode}" == "dark" ]]; then
    printf '{"text":"","tooltip":"Dark mode","class":"dark"}\n'
  else
    printf '{"text":"","tooltip":"Light mode","class":"light"}\n'
  fi
}

cmd="${1:-toggle}"
current_mode="$(get_mode)"

case "${cmd}" in
  status)
    print_status "${current_mode}"
    ;;
  light)
    apply_mode "light"
    ;;
  dark)
    apply_mode "dark"
    ;;
  toggle)
    if [[ "${current_mode}" == "dark" ]]; then
      apply_mode "light"
    else
      apply_mode "dark"
    fi
    ;;
  *)
    echo "Usage: $0 {status|toggle|light|dark}" >&2
    exit 1
    ;;
esac
