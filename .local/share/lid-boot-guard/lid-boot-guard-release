#!/bin/sh
set -u

# Counterpart to /etc/udev/rules.d/71-lid-boot-guard.rules: hand the lid switch over to
# systemd-logind once its docked check can actually succeed. logind only counts a connector
# whose "enabled" sysfs attribute is set, which happens no earlier than the compositor's first
# modeset -- long after logind's own startup check has already run.

flag=/run/lid-boot-guard-done
timeout=40

# Re-trigger the lid's *event* device, which is what logind watches. Matching it with
# "udevadm trigger --attr-match=name=Lid Switch" does not work: --attr-match tests a device's
# own attributes, and eventN has no "name" -- that lives on its inputN parent. Such a trigger
# fires on inputN and leaves eventN's udev database untouched.
trigger_lid() {
    hit=0
    for d in /sys/class/input/event*; do
        [ "$(cat "$d/device/name" 2>/dev/null)" = "Lid Switch" ] || continue
        udevadm trigger --action=change "$d" || true
        hit=$((hit + 1))
    done
    [ "$hit" -gt 0 ] || logger -t lid-boot-guard "no lid event device found to re-trigger"
}

release() {
    touch "$flag" 2>/dev/null || true
    trigger_lid
    logger -t lid-boot-guard "handed lid switch to logind ($1)"
    exit 0
}

# Never leave the lid switch withheld because this script was killed.
trap 'release "terminated"' INT TERM

# Lid open: nothing to misread, hand over immediately.
if ! grep -q closed /proc/acpi/button/lid/*/state 2>/dev/null; then
    release "lid open"
fi

i=0
while [ "$i" -lt "$timeout" ]; do
    for c in /sys/class/drm/card*-*/; do
        name=${c%/}
        name=${name##*/}
        # Strip the "cardN-" prefix. eDP-1 deliberately does not match DP-*: the internal panel
        # must not count as an external display.
        case "${name#*-}" in
            DP-*|HDMI-A-*|HDMI-B-*|DVI-*|VGA-*) ;;
            *) continue ;;
        esac
        [ "$(cat "$c/status" 2>/dev/null)" = connected ] || continue
        [ "$(cat "$c/enabled" 2>/dev/null)" = enabled ] || continue
        release "external display active: $name"
    done
    sleep 1
    i=$((i + 1))
done

# Nothing external showed up: hand over anyway, so a genuinely undocked machine with the lid
# shut still suspends.
release "timeout, no external display"
